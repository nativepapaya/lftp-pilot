<UserControl
    x:Class="LFTPPilot.App.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="SettingsPage_Loaded">
    <ScrollViewer Width="680" MinHeight="380" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18" Padding="0,0,8,0">
            <StackPanel Spacing="10">
                <TextBlock Text="Appearance" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="LFTP Pilot follows the Windows system theme, accent colors, typography, high contrast, and accessibility settings." TextWrapping="Wrap" />
                <TextBlock Text="Transfer parallelism and segmentation are selected on each transfer or mirror job; closing behavior is decided when active work exists." TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
            <Rectangle Height="1" Fill="{ThemeResource PilotBorderBrush}" />
            <StackPanel Spacing="10">
                <TextBlock Text="Diagnostics" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Create a bounded support ZIP containing current workspace and activity diagnostics. Credentials, authorization values, private-key material, and your user-profile path are redacted before the archive is written." TextWrapping="Wrap" />
                <Button Content="Create support bundle" Click="SupportBundle_Click" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding SupportBundleStatus}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
            <Rectangle Height="1" Fill="{ThemeResource PilotBorderBrush}" />
            <StackPanel Spacing="10">
                <TextBlock Text="Automatic updates" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Installed version" Style="{ThemeResource CaptionTextBlockStyle}" />
                <TextBlock Text="{Binding InstalledVersion}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" />
                    <Button Content="Get update installer" Command="{Binding OpenInstallerCommand}" Style="{ThemeResource AccentButtonStyle}" />
                </StackPanel>
                <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Message="Windows App Installer stages signed updates without interrupting transfers. When Activity has no active jobs, close the App and Agent so Windows can apply the package." />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
