<UserControl
    x:Class="LFTPPilot.App.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="SettingsPage_Loaded">
    <Grid Width="820" Height="590">
        <NavigationView
            x:Name="SettingsNavigation"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            IsPaneOpen="True"
            PaneDisplayMode="Left"
            OpenPaneLength="190"
            SelectionChanged="SettingsNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Interface" Tag="interface">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE790;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Transfers" Tag="transfers">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8AB;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="LFTP engine" Tag="engine">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE968;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Storage &amp; updates" Tag="storage">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8B7;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,4,20,20">
                <Grid>
                    <StackPanel x:Name="InterfaceSection" Spacing="18">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Interface" Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="Keep the dual-pane workspace compact while respecting Windows theme, accent, contrast, and accessibility settings." TextWrapping="Wrap" Opacity="0.72" />
                        </StackPanel>

                        <Border Style="{StaticResource PilotSettingsCardStyle}">
                            <StackPanel Spacing="14">
                                <ComboBox
                                    Header="App theme"
                                    ItemsSource="{Binding ThemeOptions}"
                                    SelectedIndex="{Binding ThemeSelectionIndex, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch"
                                    AutomationProperties.Name="Application theme" />
                                <ComboBox
                                    Header="File list density"
                                    ItemsSource="{Binding FileDensityOptions}"
                                    SelectedIndex="{Binding FileDensitySelectionIndex, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch"
                                    AutomationProperties.Name="File list density" />
                                <CheckBox Content="Show hidden local files by default" IsChecked="{Binding ShowHiddenLocal, Mode=TwoWay}" />
                                <CheckBox Content="Show dotfiles on remote servers by default" IsChecked="{Binding ShowHiddenRemote, Mode=TwoWay}" />
                                <CheckBox Content="Open the Activity panel at startup" IsChecked="{Binding ExpandActivityCenter, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Message="Each pane can still toggle hidden files and filtering without changing these defaults." />
                        <TextBlock Text="{Binding PreferencesStatus}" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" AutomationProperties.LiveSetting="Polite" />
                    </StackPanel>

                    <StackPanel x:Name="TransfersSection" Spacing="18" Visibility="Collapsed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Transfers" Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="Choose practical defaults for LFTP queues and segmented downloads. Every transfer can override them before it is queued." TextWrapping="Wrap" Opacity="0.72" />
                        </StackPanel>
                        <Border Style="{StaticResource PilotSettingsCardStyle}">
                            <Grid RowSpacing="14" ColumnSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <NumberBox Header="Parallel files in folder transfers" Minimum="1" Maximum="16" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{Binding DefaultParallelFiles, Mode=TwoWay}" />
                                <NumberBox Grid.Column="1" Header="Connections per download (segments)" Minimum="1" Maximum="16" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{Binding DefaultDownloadSegments, Mode=TwoWay}" />
                                <NumberBox Grid.Row="1" Header="Download limit (KiB/s, 0 = off)" Minimum="0" Maximum="1000000000" SmallChange="256" SpinButtonPlacementMode="Compact" Value="{Binding DownloadLimitKiB, Mode=TwoWay}" />
                                <NumberBox Grid.Row="1" Grid.Column="1" Header="Upload limit (KiB/s, 0 = off)" Minimum="0" Maximum="1000000000" SmallChange="256" SpinButtonPlacementMode="Compact" Value="{Binding UploadLimitKiB, Mode=TwoWay}" />
                            </Grid>
                        </Border>
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Title="How LFTP Pilot applies these defaults" Message="Single-file downloads use pget when segments are above 1. Folder jobs use LFTP mirror parallelism. Rate limits are scoped to each queued transfer so one site cannot silently change another site." />
                        <TextBlock Text="{Binding PreferencesStatus}" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" AutomationProperties.LiveSetting="Polite" />
                    </StackPanel>

                    <StackPanel x:Name="EngineSection" Spacing="18" Visibility="Collapsed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="LFTP engine" Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="The native App never launches LFTP directly. The background Agent owns authenticated runtime processes, queues, and session state." TextWrapping="Wrap" Opacity="0.72" />
                        </StackPanel>
                        <Border Style="{StaticResource PilotSettingsCardStyle}">
                            <StackPanel Spacing="14">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding RuntimeStatus}" TextWrapping="Wrap" />
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource PilotBorderBrush}" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Console" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="1" Text="Created only when opened and isolated from browsing and transfers." TextWrapping="Wrap" />
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource PilotBorderBrush}" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Local shell" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="1" Text="Blocked. Commands that could escape to a local shell are rejected before reaching LFTP." TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Success" Title="Authenticated packaged runtime" Message="LFTP Pilot verifies the locked LFTP/MSYS2 inventory before the Agent may start it. A custom executable path is intentionally not supported." />
                    </StackPanel>

                    <StackPanel x:Name="StorageSection" Spacing="18" Visibility="Collapsed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Storage &amp; updates" Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="Review native package storage, create sanitized diagnostics, and manage the signed App Installer update feed." TextWrapping="Wrap" Opacity="0.72" />
                        </StackPanel>
                        <Border Style="{StaticResource PilotSettingsCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="App data" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{Binding DataFolder}" IsTextSelectionEnabled="True" TextWrapping="Wrap" FontFamily="Consolas" Style="{ThemeResource CaptionTextBlockStyle}" />
                                <TextBlock Text="Managed cache" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding CacheFolder}" IsTextSelectionEnabled="True" TextWrapping="Wrap" FontFamily="Consolas" Style="{ThemeResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PilotSettingsCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Diagnostics" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Create a bounded support ZIP. Credentials, authorization values, key material, and the user-profile path are redacted before it is written." TextWrapping="Wrap" />
                                <Button Content="Create support bundle" Click="SupportBundle_Click" HorizontalAlignment="Left" />
                                <TextBlock Text="{Binding SupportBundleStatus}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PilotSettingsCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Automatic updates" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="{Binding InstalledVersion}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" />
                                    <Button Content="Get update installer" Command="{Binding OpenInstallerCommand}" Style="{ThemeResource AccentButtonStyle}" />
                                </StackPanel>
                                <TextBlock Text="Updates stage without interrupting active transfers and apply after the App and Agent are idle." Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </NavigationView>
    </Grid>
</UserControl>
