<UserControl
    x:Class="LFTPPilot.App.Views.Pages.ConnectionProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Width="820" Height="590" ColumnSpacing="18" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Saved connections" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <ListView
                Grid.Row="1"
                ItemsSource="{Binding Profiles}"
                SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                DisplayMemberPath="Name"
                SelectionMode="Single"
                IsEnabled="{Binding IsConnectionEditingEnabled}"
                AutomationProperties.Name="Saved connections" />
            <Button
                Grid.Row="2"
                Content="New connection"
                Command="{Binding NewProfileCommand}"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="Create a new connection profile" />
        </Grid>
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12" Padding="0,0,8,0">
                <TextBlock Text="Connection details" Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border
                    Visibility="{Binding HasPendingHostKeyReview, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="12"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource PilotBorderBrush}"
                    AutomationProperties.Name="SFTP host key review">
                    <StackPanel Spacing="10">
                        <InfoBar
                            IsOpen="{Binding IsHostKeyEnrollment}"
                            IsClosable="False"
                            Severity="Warning"
                            Title="New SFTP host key"
                            Message="{Binding HostKeyReviewMessage}" />
                        <InfoBar
                            IsOpen="{Binding IsHostKeyChanged}"
                            IsClosable="False"
                            Severity="Error"
                            Title="SFTP host key changed"
                            Message="{Binding HostKeyReviewMessage}" />
                        <TextBlock Text="{Binding HostKeyReviewHeading}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnSpacing="10" RowSpacing="5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Endpoint" Opacity="0.72" />
                            <TextBlock Grid.Column="1" Text="{Binding PendingHostKeyReview.Endpoint}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Row="1" Text="Presented type" Opacity="0.72" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PendingHostKeyReview.PresentedAlgorithm}" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="2" Text="Presented SHA256" Opacity="0.72" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PendingHostKeyReview.PresentedFingerprintSha256}" TextWrapping="Wrap" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Row="3" Text="Previously trusted" Opacity="0.72" Visibility="{Binding IsHostKeyChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PendingHostKeyReview.TrustedAlgorithm}" TextWrapping="Wrap" Visibility="{Binding IsHostKeyChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Grid.Row="4" Text="Trusted SHA256" Opacity="0.72" Visibility="{Binding IsHostKeyChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PendingHostKeyReview.TrustedFingerprintSha256}" TextWrapping="Wrap" FontFamily="Consolas" IsTextSelectionEnabled="True" Visibility="{Binding IsHostKeyChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <TextBlock Text="Do not continue until you verify the presented fingerprint through a separate trusted channel." TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="CancelHostKeyReviewButton" Content="Cancel" Command="{Binding CancelHostKeyReviewCommand}" Style="{ThemeResource AccentButtonStyle}" />
                            <Button Content="{Binding HostKeyApprovalLabel}" Command="{Binding ApproveHostKeyReviewCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ContentControl IsEnabled="{Binding IsConnectionEditingEnabled}" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="12">
                        <TextBox Header="Name" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="Host" Text="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="server.example.com" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="140" /></Grid.ColumnDefinitions>
                            <ComboBox Header="Protocol" ItemsSource="{Binding Protocols}" SelectedItem="{Binding Protocol, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                            <NumberBox Grid.Column="1" Header="Port" Value="{Binding Port, Mode=TwoWay}" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" />
                        </Grid>
                        <TextBox Header="Username" Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox Header="Authentication" ItemsSource="{Binding AuthenticationKinds}" SelectedItem="{Binding Authentication, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                        <Grid Visibility="{Binding IsSshKeyAuthentication, Converter={StaticResource BoolToVisibilityConverter}}" ColumnSpacing="8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBox Header="OpenSSH private key" Text="{Binding SshKeyPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="C:\Users\you\.ssh\id_ed25519" />
                            <Button Grid.Column="1" Content="Browse…" Click="SshKeyBrowse_Click" VerticalAlignment="Bottom" />
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBox Header="Initial local folder" Text="{Binding InitialLocalPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="C:\Users\you\Downloads" />
                            <Button Grid.Column="1" Content="Browse…" Click="InitialLocalPathBrowse_Click" VerticalAlignment="Bottom" />
                        </Grid>
                        <TextBox Header="Initial remote folder" Text="{Binding InitialRemotePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="/" />
                        <PasswordBox x:Name="CredentialBox" Header="{Binding CredentialHeader}" PasswordChanged="Credential_PasswordChanged" AutomationProperties.Name="Connection credential" Visibility="{Binding IsCredentialAuthentication, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <CheckBox Content="{Binding RememberCredentialLabel}" IsChecked="{Binding RememberCredential, Mode=TwoWay}" Visibility="{Binding CanRememberCredential, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Message="Credentials remain in this window until any required SFTP host-key review succeeds. Remembered passwords and private-key passphrases are then stored by the Agent with profile-bound DPAPI protection." />
                        <TextBlock Text="A profile cannot be deleted while one of its sessions owns an active managed edit. Use Active edits from the main toolbar to review or finish it first." Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" Opacity="0.72" />
                    </StackPanel>
                </ContentControl>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Padding="0,10,0,0" ColumnSpacing="12" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource PilotBorderBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Status}" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" VerticalAlignment="Center" AutomationProperties.LiveSetting="Polite" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Delete" Command="{Binding DeleteCommand}" Visibility="{Binding HasSelectedProfile, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button Content="Save changes" Command="{Binding SaveCommand}" Visibility="{Binding HasSelectedProfile, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button Content="Connect selected" Command="{Binding ConnectCommand}" Style="{ThemeResource AccentButtonStyle}" Visibility="{Binding HasSelectedProfile, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button Content="Create and connect" Command="{Binding CreateAndConnectCommand}" Style="{ThemeResource AccentButtonStyle}" Visibility="{Binding IsCreatingProfile, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
