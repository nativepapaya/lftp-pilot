<UserControl
    x:Class="LFTPPilot.App.Views.Pages.RemoteTransferPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Width="720" MinHeight="430" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Padding="0,0,8,0">
            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Title="Server-to-server transfer" Message="FXP avoids routing bytes through this PC when compatible FTP servers permit it. Client relay works across other supported connections." />
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <ComboBox Header="Source connection" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SourceProfile, Mode=TwoWay}" DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                <FontIcon Grid.Column="1" Glyph="&#xE72A;" VerticalAlignment="Bottom" Margin="0,0,0,9" />
                <ComboBox Grid.Column="2" Header="Destination connection" ItemsSource="{Binding Profiles}" SelectedItem="{Binding DestinationProfile, Mode=TwoWay}" DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
            </Grid>
            <TextBox Header="Source remote path" Text="{Binding SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Header="Destination remote path" Text="{Binding DestinationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <CheckBox Content="Overwrite an existing destination file" IsChecked="{Binding Overwrite, Mode=TwoWay}" />
            <InfoBar IsOpen="{Binding HasPlan}" IsClosable="False" Severity="Warning" Title="{Binding RouteReviewTitle}" Message="{Binding RouteReviewNote}" />
            <CheckBox Content="I reviewed the route, source, destination, and overwrite behavior and want to enqueue this transfer" IsChecked="{Binding RouteApproved, Mode=TwoWay}" Visibility="{Binding HasPlan, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Create route plan" Command="{Binding PlanCommand}" />
                <Button Content="Enqueue reviewed transfer" Command="{Binding EnqueueCommand}" Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
