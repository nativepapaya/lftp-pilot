<UserControl
    x:Class="LFTPPilot.App.Views.Pages.ConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Width="820" MinHeight="520">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <ComboBox Header="Isolated session" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession, Mode=TwoWay}" DisplayMemberPath="DisplayName" HorizontalAlignment="Stretch" />
        <InfoBar Grid.Row="1" Margin="0,10,0,8" IsOpen="True" IsClosable="False" Severity="Informational" Title="Read-only command allowlist" Message="This milestone accepts safe inspection commands such as pwd, ls, find, du, status, and help. Mutations, command metacharacters, shell, and ! local escapes are blocked until a separately reviewed unsafe mode exists." />
        <Border Grid.Row="2" Style="{StaticResource PilotCardStyle}">
            <ListView ItemsSource="{Binding Lines}" SelectionMode="None" Padding="8" AutomationProperties.Name="Console output">
                <ListView.ItemContainerStyle><Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="IsTabStop" Value="False" /></Style></ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="8" Padding="3,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Prefix}" FontFamily="Consolas" Foreground="{ThemeResource PilotAccentTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Text}" FontFamily="Consolas" TextWrapping="Wrap" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
        <Grid Grid.Row="3" Margin="0,10,0,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBox x:Name="CommandBox" Text="{Binding CommandText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter a read-only LFTP command (for example: pwd or ls -la)" KeyDown="CommandBox_KeyDown" AutomationProperties.Name="Read-only LFTP command" />
            <Button Grid.Column="1" Content="Run" Command="{Binding ExecuteCommand}" Style="{ThemeResource AccentButtonStyle}" />
            <TextBlock Grid.ColumnSpan="2" Margin="0,40,0,0" Text="{Binding Status}" Style="{ThemeResource CaptionTextBlockStyle}" />
        </Grid>
    </Grid>
</UserControl>
