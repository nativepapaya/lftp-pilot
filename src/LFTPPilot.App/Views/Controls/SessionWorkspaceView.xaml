<UserControl
    x:Class="LFTPPilot.App.Views.Controls.SessionWorkspaceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LFTPPilot.App.Views.Controls">
    <Grid Padding="0,8,0,0" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="320" />
            <ColumnDefinition Width="58" />
            <ColumnDefinition Width="*" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.ColumnSpan="3"
            Padding="14"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="{Binding Search.IsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Remote search" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Recursive from" FontSize="12" Opacity="0.72" />
                            <TextBlock Text="{Binding Search.ScopePath}" FontSize="12" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Command="{Binding Search.CloseCommand}"
                        ToolTipService.ToolTip="Close remote search (Esc)"
                        AutomationProperties.Name="Close remote search">
                        <FontIcon Glyph="&#xE711;" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="220" />
                        <ColumnDefinition Width="126" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="RemoteSearchQuery"
                        Header="Name contains"
                        PlaceholderText="File or folder name"
                        Text="{Binding Search.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="RemoteSearchQuery_KeyDown"
                        AutomationProperties.Name="Remote name to search for" />
                    <NumberBox
                        Grid.Column="1"
                        Header="Folder depth"
                        Minimum="1"
                        Maximum="128"
                        SmallChange="1"
                        SpinButtonPlacementMode="Compact"
                        Value="{Binding Search.MaxDepth, Mode=TwoWay}"
                        AutomationProperties.Name="Maximum remote search depth, 1 to 128" />
                    <CheckBox
                        Grid.Column="2"
                        Margin="0,24,0,0"
                        Content="Match case"
                        IsChecked="{Binding Search.MatchCase, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Match remote name case" />
                    <Button
                        Grid.Column="3"
                        Margin="0,24,0,0"
                        Command="{Binding Search.SearchCommand}"
                        Content="Search"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Start recursive remote search" />
                    <Button
                        Grid.Column="4"
                        Margin="0,24,0,0"
                        Command="{Binding Search.CancelCommand}"
                        Content="Cancel"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Cancel recursive remote search" />
                </Grid>

                <InfoBar
                    Grid.Row="2"
                    IsOpen="{Binding Search.HasError}"
                    IsClosable="False"
                    Severity="Error"
                    Title="Remote search failed"
                    Message="{Binding Search.Error}" />

                <Grid Grid.Row="3" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressRing
                            Width="18"
                            Height="18"
                            IsActive="{Binding Search.IsSearching}"
                            Visibility="{Binding Search.IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                            AutomationProperties.Name="Remote search in progress" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Search.Status}"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center"
                            AutomationProperties.LiveSetting="Polite" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding Search.OpenLocationCommand}"
                            Content="Open location"
                            AutomationProperties.Name="Open selected remote search result location" />
                    </Grid>
                    <ListView
                        x:Name="RemoteSearchResults"
                        Grid.Row="1"
                        MaxHeight="220"
                        ItemsSource="{Binding Search.Results}"
                        SelectedItem="{Binding Search.SelectedResult, Mode=TwoWay}"
                        SelectionMode="Single"
                        DoubleTapped="RemoteSearchResults_DoubleTapped"
                        AutomationProperties.Name="Remote search results">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,6" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="{Binding Glyph}" FontSize="14" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding ContainingPath}" TextTrimming="CharacterEllipsis" Opacity="0.72" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding KindDisplay}" Opacity="0.72" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock
                        Grid.Row="2"
                        Text="Search results are snapshots. Opening a result freshly browses its current remote location."
                        FontSize="12"
                        Opacity="0.64"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Border>

        <controls:FilePaneView x:Name="LocalPane" Grid.Row="1" IsEnabled="{Binding IsConnected}" DataContext="{Binding LocalPane}" TransferRequested="LocalPane_TransferRequested" TransferOptionsRequested="LocalPane_TransferOptionsRequested" FilesDropped="LocalPane_FilesDropped" DropRejected="Pane_DropRejected" />

        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button
                Width="42"
                Height="42"
                Command="{Binding UploadCommand}"
                ToolTipService.ToolTip="Upload selected files (Ctrl+Right)"
                AutomationProperties.Name="Upload selected files">
                <FontIcon Glyph="&#xE72A;" />
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Right" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>
            <Button
                Width="42"
                Height="42"
                Command="{Binding DownloadCommand}"
                ToolTipService.ToolTip="Download selected files (Ctrl+Left)"
                AutomationProperties.Name="Download selected files">
                <FontIcon Glyph="&#xE72B;" />
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Left" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>
            <Button
                Width="42"
                Height="42"
                IsEnabled="{Binding IsConnected}"
                ToolTipService.ToolTip="Review transfer options"
                AutomationProperties.Name="Transfer options">
                <FontIcon Glyph="&#xE713;" />
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Upload options…" Click="UploadOptions_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72A;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                        <MenuFlyoutItem Text="Download options…" Click="DownloadOptions_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72B;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <Button
                Width="42"
                Height="42"
                Command="{Binding RefreshCommand}"
                ToolTipService.ToolTip="Refresh both panes (F5)"
                AutomationProperties.Name="Refresh both panes">
                <FontIcon Glyph="&#xE72C;" />
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F5" />
                </Button.KeyboardAccelerators>
            </Button>
            <Button
                Width="42"
                Height="42"
                IsEnabled="{Binding IsConnected}"
                Click="RemoteSearch_Click"
                ToolTipService.ToolTip="Search remote names recursively (Ctrl+F)"
                AutomationProperties.Name="Open recursive remote search">
                <FontIcon Glyph="&#xE721;" />
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>
        </StackPanel>

        <controls:FilePaneView x:Name="RemotePane" Grid.Row="1" Grid.Column="2" IsEnabled="{Binding IsConnected}" DataContext="{Binding RemotePane}" TransferRequested="RemotePane_TransferRequested" TransferOptionsRequested="RemotePane_TransferOptionsRequested" FilesDropped="RemotePane_FilesDropped" DropRejected="Pane_DropRejected" RemoteEditRequested="RemotePane_RemoteEditRequested" />

        <Border
            Grid.RowSpan="2"
            Grid.ColumnSpan="3"
            MaxWidth="520"
            Padding="28"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="{Binding IsDisconnected, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE711;" FontSize="28" />
                <TextBlock Text="Saved tab is disconnected" Style="{ThemeResource SubtitleTextBlockStyle}" TextAlignment="Center" />
                <TextBlock Text="{Binding ReconnectDescription}" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.78" />
                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" Opacity="0.72" />
                <Button
                    Content="Reconnect"
                    IsEnabled="{Binding CanReconnect}"
                    Click="Reconnect_Click"
                    HorizontalAlignment="Center"
                    AutomationProperties.Name="Reconnect saved session tab" />
                <ProgressRing
                    Width="20"
                    Height="20"
                    IsActive="{Binding IsReconnecting}"
                    Visibility="{Binding IsReconnecting, Converter={StaticResource BoolToVisibilityConverter}}"
                    AutomationProperties.Name="Reconnecting saved session tab" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
