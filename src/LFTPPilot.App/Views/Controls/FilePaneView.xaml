<UserControl
    x:Class="LFTPPilot.App.Views.Controls.FilePaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives">
    <Border Style="{StaticResource PilotCardStyle}" AutomationProperties.Name="{Binding PaneSubtitle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <Grid Padding="12,10,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding PaneTitle}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="{Binding PaneSubtitle}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                </StackPanel>
                <Grid Grid.Column="1" Margin="16,0,8,0" ColumnSpacing="4" HorizontalAlignment="Right" Visibility="{Binding IsRemote, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ComboBox x:Name="QuickAccessBox" ItemsSource="{Binding QuickAccessBookmarks}" SelectedItem="{Binding SelectedBookmark, Mode=TwoWay}" SelectionChanged="QuickAccessBox_SelectionChanged" PlaceholderText="Quick Access" HorizontalAlignment="Stretch" AutomationProperties.Name="Remote Quick Access bookmarks" />
                    <Button Grid.Column="1" Command="{Binding AddCurrentBookmarkCommand}" Padding="8" ToolTipService.ToolTip="Add the current remote folder to Quick Access" AutomationProperties.Name="Bookmark current remote folder">
                        <FontIcon Glyph="&#xE734;" FontSize="14" />
                    </Button>
                    <Button Grid.Column="2" Command="{Binding RemoveBookmarkCommand}" CommandParameter="{Binding SelectedBookmark}" Padding="8" ToolTipService.ToolTip="Remove the selected Quick Access bookmark" AutomationProperties.Name="Remove remote bookmark">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    </Button>
                </Grid>
                <Button
                    Grid.Column="2"
                    Margin="0,0,4,0"
                    ToolTipService.ToolTip="File actions"
                    AutomationProperties.Name="File actions">
                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Transfer options…" Click="TransferOptionsMenuItem_Click" IsEnabled="{Binding SupportsTransfers}"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="New folder" Click="CreateDirectory_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8F4;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutItem Text="Rename or move…" Click="RenameOrMove_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Delete…" Click="DeleteEntries_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button
                    Grid.Column="3"
                    Command="{Binding RefreshCommand}"
                    ToolTipService.ToolTip="Refresh pane"
                    AutomationProperties.Name="Refresh pane">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="10,2,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="PathBox"
                    Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="PathBox_KeyDown"
                    PlaceholderText="Path"
                    AutomationProperties.Name="Current folder path">
                    <TextBox.Header>
                        <TextBlock Text="Location" Visibility="Collapsed" />
                    </TextBox.Header>
                </TextBox>
                <TextBox
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Filter this folder"
                    AutomationProperties.Name="Filter files" />
                <ProgressBar Grid.ColumnSpan="2" IsIndeterminate="True" VerticalAlignment="Bottom" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <Grid Grid.Row="2" Padding="10,0,6,0" Background="{ThemeResource PilotSubtleBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" MinWidth="130" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition x:Name="HeaderSizeColumn" Width="92" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition x:Name="HeaderModifiedColumn" Width="142" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition x:Name="HeaderTypeColumn" Width="94" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Padding="4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Command="{Binding SortCommand}" CommandParameter="Name" AutomationProperties.Name="Sort by name">
                    <TextBlock Text="Name" Style="{ThemeResource CaptionTextBlockStyle}" />
                </Button>
                <primitives:Thumb Grid.Column="2" DragDelta="NameSizeSplitter_DragDelta" DragCompleted="ColumnSplitter_DragCompleted" Background="{ThemeResource PilotBorderBrush}" Opacity="0.55" AutomationProperties.Name="Resize name and size columns" />
                <Button Grid.Column="3" Padding="4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Background="Transparent" BorderThickness="0" Command="{Binding SortCommand}" CommandParameter="Size" AutomationProperties.Name="Sort by size">
                    <TextBlock Text="Size" Style="{ThemeResource CaptionTextBlockStyle}" />
                </Button>
                <primitives:Thumb Grid.Column="4" DragDelta="SizeModifiedSplitter_DragDelta" DragCompleted="ColumnSplitter_DragCompleted" Background="{ThemeResource PilotBorderBrush}" Opacity="0.55" AutomationProperties.Name="Resize size and modified columns" />
                <Button Grid.Column="5" Padding="4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Command="{Binding SortCommand}" CommandParameter="Modified" AutomationProperties.Name="Sort by modified time">
                    <TextBlock Text="Modified" Style="{ThemeResource CaptionTextBlockStyle}" />
                </Button>
                <primitives:Thumb Grid.Column="6" DragDelta="ModifiedTypeSplitter_DragDelta" DragCompleted="ColumnSplitter_DragCompleted" Background="{ThemeResource PilotBorderBrush}" Opacity="0.55" AutomationProperties.Name="Resize modified and type columns" />
                <Button Grid.Column="7" Padding="4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Command="{Binding SortCommand}" CommandParameter="Type" AutomationProperties.Name="Sort by type">
                    <TextBlock Text="Type" Style="{ThemeResource CaptionTextBlockStyle}" />
                </Button>
            </Grid>

            <ListView
                x:Name="FilesList"
                Grid.Row="3"
                ItemsSource="{Binding Entries}"
                SelectionMode="Extended"
                IsItemClickEnabled="True"
                CanDragItems="{Binding SupportsTransfers}"
                CanReorderItems="False"
                AllowDrop="{Binding SupportsTransfers}"
                SelectionChanged="FilesList_SelectionChanged"
                DoubleTapped="FilesList_DoubleTapped"
                DragItemsStarting="FilesList_DragItemsStarting"
                DragItemsCompleted="FilesList_DragItemsCompleted"
                DragOver="FilesList_DragOver"
                Drop="FilesList_Drop"
                AutomationProperties.Name="Files"
                ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="44" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Open" Click="OpenMenuItem_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Edit remote file…" Click="RemoteEditMenuItem_Click" IsEnabled="{Binding CanRemoteEdit}" Visibility="{Binding IsRemote, Converter={StaticResource BoolToVisibilityConverter}}">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Transfer to other pane" Click="TransferMenuItem_Click" IsEnabled="{Binding SupportsTransfers}">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AB;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Transfer options…" Click="TransferOptionsMenuItem_Click" IsEnabled="{Binding SupportsTransfers}">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="New folder" Click="CreateDirectory_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8F4;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                        <MenuFlyoutItem Text="Rename or move…" Click="RenameOrMove_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                        <MenuFlyoutItem Text="Delete…" Click="DeleteEntries_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Copy path" Click="CopyPathMenuItem_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Refresh" Click="RefreshMenuItem_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72C;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </ListView.ContextFlyout>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="6,0" Loaded="FileRow_Loaded" Unloaded="FileRow_Unloaded">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" MinWidth="130" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="94" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{Binding Glyph}" FontSize="15" Opacity="0.82" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding DetailDisplay}" FontSize="10" Opacity="0.62" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="{Binding SizeDisplay}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="{Binding ModifiedDisplay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="7" Text="{Binding TypeDisplay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid Grid.Row="4" Padding="10,0" Background="{ThemeResource PilotSubtleBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding SelectionSummary}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding SortIndicator}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" Opacity="0.65" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
