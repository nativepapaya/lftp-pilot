<UserControl
    x:Class="LFTPPilot.App.Views.Controls.ActivityCenterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="Activity center">
        <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE9D9;" FontSize="15" />
                <TextBlock Text="Activity" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Border Padding="7,1" CornerRadius="9" Background="{ThemeResource PilotSubtleBrush}">
                    <TextBlock Text="{Binding ActiveCount}" FontSize="11" />
                </Border>
            </StackPanel>
        </Expander.Header>
        <Border Style="{StaticResource PilotCardStyle}" Height="220">
            <TabView IsAddTabButtonVisible="False" CanDragTabs="False">
                <TabViewItem Header="Transfers">
                    <ListView ItemsSource="{Binding Jobs}" SelectionMode="Single" AutomationProperties.Name="Active transfers">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /></Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,5" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Status}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding State}" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="2" Value="{Binding Progress}" Maximum="1" Height="4" VerticalAlignment="Center" AutomationProperties.Name="Transfer progress" />
                                    <Button Grid.Column="3" Margin="6,0,0,0" Padding="8,4" Content="Cancel" Click="CancelJob_Click" IsEnabled="{Binding State, Converter={StaticResource JobStateToCancellableConverter}}" ToolTipService.ToolTip="Cancel this queued, active, paused, or scheduled job" AutomationProperties.Name="Cancel job" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
                <TabViewItem Header="History">
                    <ListView ItemsSource="{Binding History}" SelectionMode="Single" AutomationProperties.Name="Transfer history">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /></Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,5" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Outcome}" />
                                    <TextBlock Grid.Column="2" Text="{Binding FinishedAt}" Style="{ThemeResource CaptionTextBlockStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
                <TabViewItem Header="Log">
                    <ListView ItemsSource="{Binding Log}" SelectionMode="Single" AutomationProperties.Name="Activity log">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /></Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,4" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TimeDisplay}" FontFamily="Consolas" />
                                    <TextBlock Grid.Column="1" Text="{Binding Level}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Source}" Opacity="0.72" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
            </TabView>
        </Border>
    </Expander>
</UserControl>
