<Window
    x:Class="LFTPPilot.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LFTPPilot.App.Views.Controls"
    xmlns:pages="using:LFTPPilot.App.Views.Pages"
    Title="LFTP Pilot">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="8,0,4,0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Width="24" Height="24" CornerRadius="6" Background="{ThemeResource PilotAccentBrush}">
                    <FontIcon Glyph="&#xE8AB;" FontSize="13" Foreground="{ThemeResource PilotOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" AutomationProperties.Name="LFTP Pilot" />
                </Border>
                <TextBlock Text="LFTP Pilot" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <Grid Grid.Column="1" Margin="14,0,8,0">
                <TabView
                    x:Name="SessionTabs"
                    Height="40"
                    TabItemsSource="{Binding Sessions}"
                    SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                    Visibility="{Binding HasSessions, Converter={StaticResource BoolToVisibilityConverter}}"
                    IsAddTabButtonVisible="True"
                    TabWidthMode="SizeToContent"
                    AddTabButtonClick="SessionTabs_AddTabButtonClick"
                    TabCloseRequested="SessionTabs_TabCloseRequested"
                    AutomationProperties.Name="Connection sessions">
                    <TabView.TabItemTemplate>
                        <DataTemplate>
                            <TabViewItem IsClosable="True" ToolTipService.ToolTip="{Binding StatusText}">
                                <TabViewItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource PilotAccentBrush}" Opacity="{Binding ConnectionStateOpacity}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TabViewItem.Header>
                            </TabViewItem>
                        </DataTemplate>
                    </TabView.TabItemTemplate>
                </TabView>
                <TextBlock
                    Text="No active session"
                    Margin="8,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Opacity="0.58"
                    Visibility="{Binding HasNoSessions, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <StackPanel Grid.Column="2" Margin="0,0,144,0" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                <Button Style="{StaticResource PilotTitleBarButtonStyle}" Click="Connect_Click" AutomationProperties.Name="Open connection manager">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE968;" FontSize="13" /><TextBlock Text="Connections" Style="{ThemeResource CaptionTextBlockStyle}" /></StackPanel>
                    <Button.KeyboardAccelerators><KeyboardAccelerator Key="N" Modifiers="Control" /></Button.KeyboardAccelerators>
                </Button>
                <Button Style="{StaticResource PilotTitleBarButtonStyle}" AutomationProperties.Name="Open LFTP tools">
                    <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE90F;" FontSize="13" /><TextBlock Text="Tools" Style="{ThemeResource CaptionTextBlockStyle}" /><FontIcon Glyph="&#xE70D;" FontSize="9" /></StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Synchronize folders…" Click="Mirror_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE895;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutItem Text="Server-to-server transfer…" Click="RemoteTransfer_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AB;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutItem Text="Managed remote edits…" Click="ActiveEdits_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Advanced LFTP console…" Click="Console_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE756;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Style="{StaticResource PilotToolbarButtonStyle}" Click="Help_Click" ToolTipService.ToolTip="Keyboard &amp; mouse (F1)" AutomationProperties.Name="Keyboard and mouse help">
                    <FontIcon Glyph="&#xE897;" FontSize="13" />
                    <Button.KeyboardAccelerators><KeyboardAccelerator Key="F1" /></Button.KeyboardAccelerators>
                </Button>
                <Button Style="{StaticResource PilotToolbarButtonStyle}" Click="Settings_Click" ToolTipService.ToolTip="Settings" AutomationProperties.Name="Open settings"><FontIcon Glyph="&#xE713;" FontSize="13" /></Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="8,0,8,6" Spacing="4">
            <InfoBar
                IsOpen="{Binding IsDemoMode}"
                IsClosable="False"
                Severity="Informational"
                Title="Interactive diagnostic workspace"
                Message="The explicit diagnostic demo transport is active; commands do not reach the Agent." />
            <InfoBar
                IsOpen="{Binding HasAgentError}"
                IsClosable="False"
                Severity="Error"
                Title="Agent connection failed"
                Message="{Binding AgentStatus}">
                <InfoBar.ActionButton>
                    <Button Content="Retry" Command="{Binding InitializeCommand}" />
                </InfoBar.ActionButton>
            </InfoBar>
        </StackPanel>

        <Grid Grid.Row="2" Margin="8,0,8,6">
            <ProgressRing
                Width="48"
                Height="48"
                IsActive="{Binding IsLoading}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Canvas.ZIndex="10"
                AutomationProperties.Name="Loading workspace" />
            <Grid Visibility="{Binding HasSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:SessionWorkspaceView
                    DataContext="{Binding SelectedSession}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
            </Grid>

            <Grid
                Visibility="{Binding HasNoSessions, Converter={StaticResource BoolToVisibilityConverter}}"
                ColumnSpacing="8"
                AutomationProperties.Name="Disconnected dual pane workspace">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="360" />
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <controls:FilePaneView DataContext="{Binding OfflineLocalPane}" />

                <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Width="42" Height="44" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Connect to download files" AutomationProperties.Name="Download unavailable until connected"><StackPanel Spacing="0"><FontIcon Glyph="&#xE72B;" FontSize="15" /><TextBlock Text="GET" FontSize="9" HorizontalAlignment="Center" /></StackPanel></Button>
                    <StackPanel Spacing="3"><Ellipse Width="6" Height="6" Fill="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Center" /><TextBlock Text="Offline" FontSize="10" Opacity="0.6" /></StackPanel>
                    <Button Width="42" Height="44" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Connect to upload files" AutomationProperties.Name="Upload unavailable until connected"><StackPanel Spacing="0"><FontIcon Glyph="&#xE72A;" FontSize="15" /><TextBlock Text="PUT" FontSize="9" HorizontalAlignment="Center" /></StackPanel></Button>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource PilotCardStyle}" AutomationProperties.Name="Remote files not connected">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="34" /><RowDefinition Height="28" /><RowDefinition Height="*" /><RowDefinition Height="24" /></Grid.RowDefinitions>
                        <Grid Padding="8,2,6,2">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center"><FontIcon Glyph="&#xE968;" FontSize="14" Opacity="0.8" /><TextBlock Text="Remote" Style="{ThemeResource BodyStrongTextBlockStyle}" /></StackPanel>
                        </Grid>
                        <Grid Grid.Row="1" Padding="8,1"><TextBox Text="/" IsReadOnly="True" Opacity="0.65" AutomationProperties.Name="Remote folder path unavailable" /></Grid>
                        <Grid Grid.Row="2" Padding="8,0" Background="{ThemeResource PilotSubtleBrush}"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="92" /><ColumnDefinition Width="142" /><ColumnDefinition Width="94" /></Grid.ColumnDefinitions><TextBlock Text="Name" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" /><TextBlock Grid.Column="1" Text="Size" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" /><TextBlock Grid.Column="2" Text="Modified" Style="{ThemeResource CaptionTextBlockStyle}" Margin="8,0,0,0" VerticalAlignment="Center" /><TextBlock Grid.Column="3" Text="Type" Style="{ThemeResource CaptionTextBlockStyle}" Margin="8,0,0,0" VerticalAlignment="Center" /></Grid>
                        <StackPanel Grid.Row="3" Spacing="12" MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE711;" FontSize="24" Opacity="0.65" />
                            <TextBlock Text="Not connected" Style="{ThemeResource BodyStrongTextBlockStyle}" TextAlignment="Center" />
                            <TextBlock Text="Choose a saved connection or add a new server to start a remote session." TextWrapping="Wrap" TextAlignment="Center" Opacity="0.72" />
                            <Button Content="Open connection manager" Click="Connect_Click" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Center" AutomationProperties.Name="Add or choose a remote connection" />
                            <TextBlock Text="{Binding OfflineWorkspaceStatus}" TextWrapping="Wrap" TextAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.65" />
                        </StackPanel>
                        <Grid Grid.Row="4" Padding="8,0" Background="{ThemeResource PilotSubtleBrush}"><TextBlock Text="0 items" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" /></Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <controls:ActivityCenterView Grid.Row="3" Margin="8,0,8,8" DataContext="{Binding Activity}" />
    </Grid>
</Window>
